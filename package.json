{
  "name": "vue-mdbootstrap",
  "version": "2.2.2",
  "description": "Material Design UI Component Library for Vue.js",
  "author": {
    "name": "Ahmad Fajar",
    "email": "ahmad.fajar234@hotmail.com"
  },
  "license": "BSD-3-Clause",
  "keywords": [
    "bootstrap",
    "tailwind",
    "vue",
    "vue3",
    "vue-component",
    "vue-mdbootstrap"
  ],
  "homepage": "https://ahmadfajar.github.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/ahmadfajar/vue-mdbootstrap"
  },
  "type": "module",
  "main": "dist/vue-mdb.esm.min.js",
  "module": "dist/vue-mdb.esm.mjs",
  "styles": "dist/bundle-core.min.css",
  "styles-color": "dist/decorator-colors.min.css",
  "theme-light": "dist/theme-light.min.css",
  "theme-dark": "dist/theme-dark.min.css",
  "types": "dist/vue-mdb.d.ts",
  "unpkg": "dist/vue-mdb.umd.min.js",
  "jsdelivr": "dist/vue-mdb.umd.min.js",
  "files": [
    "dist",
    "scss",
    "component.d.ts",
    "package.json",
    "CHANGELOG.md",
    "LICENSE.md",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/vue-mdb.d.ts",
        "default": "./dist/vue-mdb.esm.mjs"
      },
      "require": {
        "types": "./dist/vue-mdb.d.ts",
        "default": "./dist/vue-mdb.cjs"
      }
    },
    "./component": "./component.d.ts",
    "./package.json": "./package.json",
    "./styles": "./dist/bundle-core.min.css",
    "./styles-color": "./dist/decorator-colors.css",
    "./theme-light": "./dist/theme-light.css",
    "./theme-dark": "./dist/theme-dark.css",
    "./scss/color-vars": "./scss/_color-vars.scss",
    "./scss/variables": "./scss/_variables.scss",
    "./scss/mixins/css3/borders": "./scss/mixins/css3/_borders.scss",
    "./scss/mixins/css3/breakpoints": "./scss/mixins/css3/_breakpoints.scss",
    "./scss/mixins/css3/grid": "./scss/mixins/css3/_grid.scss",
    "./scss/mixins/css3/placeholder": "./scss/mixins/css3/_placeholder.scss",
    "./scss/mixins/css3/text-decorator": "./scss/mixins/css3/_text-decorator.scss",
    "./scss/mixins/alert": "./scss/mixins/_alert.scss",
    "./scss/mixins/badge": "./scss/mixins/_badge.scss",
    "./scss/mixins/button": "./scss/mixins/_button.scss",
    "./scss/mixins/checkbox": "./scss/mixins/_checkbox.scss",
    "./scss/mixins/chip": "./scss/mixins/_chip.scss",
    "./scss/mixins/dropdown-menu": "./scss/mixins/_dropdown-menu.scss",
    "./scss/mixins/field": "./scss/mixins/_field.scss",
    "./scss/mixins/listview": "./scss/mixins/_listview.scss",
    "./scss/mixins/progress": "./scss/mixins/_progress.scss",
    "./scss/mixins/radio": "./scss/mixins/_radio.scss",
    "./scss/mixins/switch": "./scss/mixins/_switch.scss",
    "./scss/mixins/theme-maker": "./scss/mixins/_theme-maker.scss",
    "./scss/mixins/transitions": "./scss/mixins/_transitions.scss",
    "./scss/utils/color-helper": "./scss/utils/_color-helper.scss"
  },
  "scripts": {
    "dev": "rimraf dist && run-p type-check build:dev css:compile-core css:compile-light css:compile-dark css:compile-color",
    "prod": "rimraf dist && run-p type-check build:prod css:compile-core css:compile-light css:compile-dark css:compile-color && run-s css:minify-core css:minify-light css:minify-dark css:minify-color",
    "dist": "rimraf dist && run-p type-check build:dev build:prod build:lib build:types css:compile-core css:compile-light css:compile-dark css:compile-color && run-s css:minify-core css:minify-light css:minify-dark css:minify-color",
    "build:dev": "vite build",
    "build:lib": "vite build --config vite.config.lib.ts",
    "build:prod": "vite build --config vite.config.prod.ts",
    "build:types": "rollup --config rollup.config.dts.mjs",
    "css:compile-core": "sass --no-source-map src/bundle.scss dist/bundle-core.css",
    "css:beauty-core": "cleancss --format beautify -o dist/bundle-core.css dist/bundle-core.css",
    "css:minify-core": "cleancss -o dist/bundle-core.min.css dist/bundle-core.css",
    "css:compile-light": "sass --no-source-map scss/main/theme-light.scss dist/theme-light.css",
    "css:minify-light": "cleancss -o dist/theme-light.min.css dist/theme-light.css",
    "css:compile-dark": "sass --no-source-map scss/main/theme-dark.scss dist/theme-dark.css",
    "css:minify-dark": "cleancss -o dist/theme-dark.min.css dist/theme-dark.css",
    "css:compile-color": "sass --no-source-map scss/custom/colors.scss dist/decorator-colors.css",
    "css:minify-color": "cleancss -o dist/decorator-colors.min.css dist/decorator-colors.css",
    "css:compile-custom": "sass --no-source-map scss/custom/components.scss dist/theme-custom.css",
    "css:minify-custom": "cleancss -o dist/theme-custom.min.css dist/theme-custom.css",
    "type-check": "tsc --noEmit -p tsconfig.build.json --composite false"
  },
  "peerDependencies": {
    "vue": ">= 3.5.0"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "fast-xml-parser": "^5.6.0",
    "lodash-es": "^4.18.1",
    "luxon": "^3.7.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/body-scroll-lock": "^3.1.2",
    "@types/lodash-es": "^4.17.12",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.6.0",
    "@types/sass": "^1.45.0",
    "@types/vue": "^2.0.0",
    "@vue/tsconfig": "^0.9.1",
    "body-scroll-lock": "^4.0.0-beta.0",
    "bootstrap": "^5.3.8",
    "clean-css-cli": "^5.6.3",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-sort-imports": "^1.8.11",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.1",
    "rollup-plugin-dts": "^6.4.1",
    "sass": "^1.99.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "browserslist": [
    "> 5%",
    "last 2 versions",
    "not dead",
    "not ie <= 11"
  ],
  "packageManager": "yarn@4.13.0"
}
